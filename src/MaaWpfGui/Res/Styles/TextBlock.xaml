<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:controls="clr-namespace:MaaWpfGui.Styles.Controls">

    <!--  A Style that affects all TextBlocks  -->
    <Style
        x:Key="MaaTextBlockDefaultStyle"
        BasedOn="{StaticResource TextBlockDefault}"
        TargetType="{x:Type controls:TextBlock}" />

    <Style BasedOn="{StaticResource MaaTextBlockDefaultStyle}" TargetType="{x:Type controls:TextBlock}" />

</ResourceDictionary>
