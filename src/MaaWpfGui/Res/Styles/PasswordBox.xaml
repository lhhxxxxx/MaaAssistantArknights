<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:hc="https://handyorg.github.io/handycontrol">

    <Style
        x:Key="MaaPasswordBoxDefaultStyle"
        BasedOn="{StaticResource PasswordBoxExtend}"
        TargetType="{x:Type PasswordBox}">
        <Setter Property="Background" Value="{DynamicResource RegionBrushOpacity25}" />
    </Style>

    <Style BasedOn="{StaticResource MaaPasswordBoxDefaultStyle}" TargetType="{x:Type PasswordBox}" />

    <Style
        x:Key="MaaHandyPasswordBoxDefaultStyle"
        BasedOn="{StaticResource {x:Type hc:PasswordBox}}"
        TargetType="{x:Type hc:PasswordBox}">
        <Setter Property="Background" Value="{DynamicResource RegionBrushOpacity25}" />
    </Style>

    <Style BasedOn="{StaticResource MaaHandyPasswordBoxDefaultStyle}" TargetType="{x:Type hc:PasswordBox}" />

</ResourceDictionary>
